{
  "expo": {
    "name": "Syde Vibe",
    "slug": "syde",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#B8D4E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sidebyside8.syde",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationUsageDescription": "Syde Vibe uses notifications to alert you about new matches and messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B8D4E8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sidebyside8.syde"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9c6c46b9-81e7-44b2-985e-9c2af69b05ae"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/logo2.png",
          "color": "#1B6CA8",
          "sounds": []
        }
      ]
    ]
  }
}